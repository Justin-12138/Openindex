                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " and ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "1\\%",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " SDS, the phage solution was mixed and incubated at ",
                  "bbox": [
