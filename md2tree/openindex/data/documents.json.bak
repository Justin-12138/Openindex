                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": ". The ssDNA ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "(7249\\mathrm{nt})",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " containing supernatant was collected and precipitated in ethanol ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "(70\\%)",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " on ice for ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "2\\mathrm{h}",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": ". After centrifuging at ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "12,000g",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " for ",
                  "bbox": [
                    39,
