                  ],
                  "type": "text"
                },
                {
                  "text": "3\\mathrm{min}",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": ". After the addition of potassium acetate ",
                  "bbox": [
                    39,
