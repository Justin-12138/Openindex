              ],
              "type": "title",
              "text": "IV. CONCLUSION",
              "line_count": 1,
              "page_size": [
                612,
                792
              ],
              "spans": [
                {
                  "text": "IV. CONCLUSION",
                  "bbox": [
                    397,
                    655,
                    477,
                    666
                  ],
                  "type": "text"
