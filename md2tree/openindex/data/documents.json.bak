                  "text": "30\\mathrm{min}",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " to remove the bacteria pellets. NaCl ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "(30\\mathrm{g / l})",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " and PEG ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "(40\\mathrm{g / l})",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " were added to the supernatant containing phages and the mixture was incubated on ice for ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "1\\mathrm{h}",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": ". After ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "30\\mathrm{min}",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " centrifugation at ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "10,000g",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": ", the phage pellet was collected and suspended in Tris-Cl ",
                  "bbox": [
                    39,
                    239,
                    292,
                    429
                  ],
                  "type": "text"
                },
                {
                  "text": "(10\\mathrm{mM},\\mathrm{pH}8.5)",
                  "bbox": [
