                    140
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " FBS, ",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "text"
                },
                {
                  "text": "1\\%",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " penicillin and streptomycin. Mouse brain endothelial cells (bEnd.3) were maintained in high-glucose DMEM supplemented with ",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "text"
                },
                {
                  "text": "10\\%",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " FBS, ",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "text"
                },
                {
                  "text": "100\\mathrm{U / ml}",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " penicillin and ",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "text"
                },
                {
                  "text": "100\\mathrm{U / ml}",
                  "bbox": [
                    39,
                    59,
                    292,
                    140
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " streptomycin. Cell line authentication was performed by short tandem repeat DNA profiling and comparison with a reference database. The cells were cultured at ",
                  "bbox": [
