                    289,
                    553,
                    400
                  ],
                  "type": "text"
                },
                {
                  "text": "15^{\\circ}\\mathrm{C}",
                  "bbox": [
                    299,
                    289,
                    553,
                    400
                  ],
                  "type": "inline_equation"
                },
                {
                  "text": " at a rate of ",
                  "bbox": [
